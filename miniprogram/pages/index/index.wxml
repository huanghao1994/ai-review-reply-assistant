<view class="page">
  <view class="hero">
    <view class="eyebrow">门店工作台</view>
    <view class="title">评价处理工作台</view>
    <view class="subtitle">识别差评原因，生成回复，并沉淀门店复盘记录。</view>
  </view>

  <view class="metrics">
    <view class="metric-card">
      <view class="metric-value">3</view>
      <view class="metric-label">回复版本</view>
    </view>
    <view class="metric-card">
      <view class="metric-value">5</view>
      <view class="metric-label">免费试用</view>
    </view>
    <view class="metric-card">
      <view class="metric-value">50</view>
      <view class="metric-label">历史保留</view>
    </view>
  </view>

  <view class="section panel">
    <view class="label">店铺行业</view>
    <view class="pill-row">
      <view wx:for="{{industries}}" wx:key="*this" class="pill {{industry === item ? 'active' : ''}}" bindtap="selectIndustry" data-value="{{item}}">{{item}}</view>
    </view>
  </view>

  <view class="section panel">
    <view class="label">回复风格</view>
    <view class="pill-row">
      <view wx:for="{{tones}}" wx:key="*this" class="pill {{tone === item ? 'active' : ''}}" bindtap="selectTone" data-value="{{item}}">{{item}}</view>
    </view>
  </view>

  <view class="section panel strategy-panel">
    <view class="label">回复策略</view>
    <view class="strategy-grid">
      <view class="strategy-item active">公开回复</view>
      <view class="strategy-item">私信补偿</view>
      <view class="strategy-item">内部复盘</view>
    </view>
  </view>

  <view class="section panel">
    <view class="label">差评内容</view>
    <textarea class="textarea" maxlength="800" placeholder="例如：等了一个多小时才送到，菜都凉了，客服也没人回复。" value="{{reviewText}}" bindinput="onReviewInput" />
    <view class="counter">{{reviewText.length}} / 800</view>
  </view>

  <button class="button-primary generate" loading="{{loading}}" disabled="{{loading}}" bindtap="submit">分析并生成</button>

  <view class="section notice">
    <view class="hint">本工具只提供回复建议，不承诺删除差评，不生成骚扰、威胁、诱导刷好评内容。</view>
  </view>
</view>
