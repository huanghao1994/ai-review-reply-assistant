.hero {
  background: linear-gradient(135deg, #2563eb 0%, #0ea5e9 100%);
  border-radius: 24rpx;
  box-shadow: 0 22rpx 50rpx rgba(37, 99, 235, 0.26);
  color: #ffffff;
  margin-bottom: 24rpx;
  overflow: hidden;
  padding: 34rpx 30rpx;
  position: relative;
}

.hero::after {
  background: rgba(255, 255, 255, 0.16);
  border-radius: 999rpx;
  content: "";
  height: 180rpx;
  position: absolute;
  right: -64rpx;
  top: -54rpx;
  width: 180rpx;
}

.eyebrow {
  background: rgba(255, 255, 255, 0.18);
  border: 1rpx solid rgba(255, 255, 255, 0.24);
  border-radius: 999rpx;
  display: inline-block;
  font-size: 22rpx;
  font-weight: 700;
  margin-bottom: 18rpx;
  padding: 8rpx 18rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 900;
  letter-spacing: 0;
  line-height: 1.25;
  max-width: 520rpx;
  position: relative;
  z-index: 1;
}

.subtitle {
  color: rgba(255, 255, 255, 0.82);
  font-size: 26rpx;
  line-height: 1.5;
  margin-top: 12rpx;
  max-width: 520rpx;
  position: relative;
  z-index: 1;
}

.metrics {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.metric-card {
  background: #ffffff;
  border: 1rpx solid #cfe0f5;
  border-radius: 18rpx;
  flex: 1;
  padding: 20rpx 10rpx;
  text-align: center;
}

.metric-value {
  color: #2563eb;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1;
}

.metric-label {
  color: #64748b;
  font-size: 22rpx;
  margin-top: 10rpx;
}

.strategy-grid {
  display: flex;
  gap: 14rpx;
}

.strategy-item {
  background: #eef6ff;
  border: 1rpx solid #cfe0f5;
  border-radius: 14rpx;
  color: #475569;
  flex: 1;
  font-size: 24rpx;
  font-weight: 700;
  padding: 18rpx 6rpx;
  text-align: center;
}

.strategy-item.active {
  background: #dbeafe;
  border-color: #93c5fd;
  color: #1d4ed8;
}

.counter {
  color: #94a3b8;
  font-size: 22rpx;
  margin-top: 12rpx;
  text-align: right;
}

.generate {
  height: 92rpx;
  line-height: 92rpx;
  margin: 10rpx 0 28rpx;
}

.notice {
  padding: 0 4rpx;
}
