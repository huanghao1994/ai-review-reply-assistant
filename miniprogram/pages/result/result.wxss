.report-hero {
  align-items: center;
  background: linear-gradient(135deg, #2563eb 0%, #0ea5e9 100%);
  border-radius: 24rpx;
  box-shadow: 0 22rpx 50rpx rgba(37, 99, 235, 0.24);
  color: #ffffff;
  display: flex;
  justify-content: space-between;
  padding: 30rpx;
}

.eyebrow {
  color: rgba(255, 255, 255, 0.78);
  font-size: 22rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.report-title {
  font-size: 40rpx;
  font-weight: 900;
}

.priority-badge {
  background: rgba(255, 255, 255, 0.18);
  border: 1rpx solid rgba(255, 255, 255, 0.32);
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 900;
  min-width: 86rpx;
  padding: 16rpx 10rpx;
  text-align: center;
}

.insight-grid {
  display: flex;
  gap: 18rpx;
}

.insight-card {
  background: #ffffff;
  border: 1rpx solid #cfe0f5;
  border-radius: 18rpx;
  flex: 1;
  padding: 24rpx;
}

.insight-label {
  color: #64748b;
  font-size: 22rpx;
  margin-bottom: 10rpx;
}

.insight-value {
  color: #1d4ed8;
  font-size: 32rpx;
  font-weight: 900;
}

.keywords {
  color: #1e293b;
  font-size: 28rpx;
  line-height: 1.55;
}

.option-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option-card {
  background: #f8fbff;
  border: 1rpx solid #cfe0f5;
  border-radius: 16rpx;
  padding: 22rpx;
}

.option-card.active {
  background: #dbeafe;
  border-color: #60a5fa;
}

.option-title {
  color: #0f172a;
  font-size: 28rpx;
  font-weight: 800;
}

.option-desc {
  color: #64748b;
  font-size: 23rpx;
  line-height: 1.45;
  margin-top: 8rpx;
}

.style-row,
.compensation-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.style-chip,
.compensation-chip {
  background: #e0f2fe;
  border: 1rpx solid #bfdbfe;
  border-radius: 999rpx;
  color: #075985;
  font-size: 24rpx;
  font-weight: 700;
  padding: 14rpx 22rpx;
}

.style-chip.active {
  background: #2563eb;
  border-color: #2563eb;
  color: #ffffff;
}

.compensation-chip {
  background: #fff7ed;
  border-color: #fed7aa;
  color: #9a3412;
}

.compensation-chip.disabled {
  opacity: 0.5;
}

.compensation-hint {
  margin-bottom: 18rpx;
}

.success-tip,
.loading-text {
  background: #dcfce7;
  border-radius: 12rpx;
  color: #166534;
  font-size: 24rpx;
  line-height: 1.45;
  margin-top: 18rpx;
  padding: 16rpx;
}

.loading-text {
  background: #eff6ff;
  color: #1d4ed8;
}

.card-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.copy {
  background: #e0f2fe;
  border-radius: 999rpx;
  color: #075985;
  font-weight: 700;
  margin: 0;
}

.reply-text,
.suggestion {
  color: #1e293b;
  font-size: 28rpx;
  line-height: 1.65;
  white-space: pre-wrap;
}

.back-btn {
  height: 92rpx;
  line-height: 92rpx;
}
