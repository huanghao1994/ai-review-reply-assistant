.report-hero {
  align-items: center;
  background: linear-gradient(135deg, #2563eb 0%, #0ea5e9 100%);
  border-radius: 24rpx;
  box-shadow: 0 22rpx 50rpx rgba(37, 99, 235, 0.24);
  color: #ffffff;
  display: flex;
  justify-content: space-between;
  padding: 30rpx;
}

.eyebrow {
  color: rgba(255, 255, 255, 0.78);
  font-size: 22rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.report-title {
  font-size: 40rpx;
  font-weight: 900;
}

.priority-badge {
  background: rgba(255, 255, 255, 0.18);
  border: 1rpx solid rgba(255, 255, 255, 0.32);
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 900;
  min-width: 86rpx;
  padding: 16rpx 10rpx;
  text-align: center;
}

.insight-grid {
  display: flex;
  gap: 18rpx;
}

.insight-card {
  background: #ffffff;
  border: 1rpx solid #cfe0f5;
  border-radius: 18rpx;
  flex: 1;
  padding: 24rpx;
}

.insight-label {
  color: #64748b;
  font-size: 22rpx;
  margin-bottom: 10rpx;
}

.insight-value {
  color: #1d4ed8;
  font-size: 34rpx;
  font-weight: 900;
}

.card-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.copy {
  background: #e0f2fe;
  border-radius: 999rpx;
  color: #075985;
  font-weight: 700;
  margin: 0;
}

.reply-text,
.suggestion {
  color: #1e293b;
  font-size: 28rpx;
  line-height: 1.65;
  white-space: pre-wrap;
}

.back-btn {
  height: 92rpx;
  line-height: 92rpx;
}
