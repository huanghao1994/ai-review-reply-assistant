.history-head {
  margin: 10rpx 4rpx 28rpx;
}

.history-title {
  color: #0f172a;
  font-size: 40rpx;
  font-weight: 900;
}

.history-subtitle {
  color: #64748b;
  font-size: 25rpx;
  line-height: 1.5;
  margin-top: 10rpx;
}

.empty {
  margin-top: 80rpx;
  text-align: center;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 14rpx;
}

.item {
  margin-bottom: 20rpx;
}

.meta {
  align-items: center;
  color: #6b7280;
  display: flex;
  font-size: 24rpx;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.reason-tag {
  background: #e0f2fe;
  border-radius: 999rpx;
  color: #075985;
  font-size: 22rpx;
  font-weight: 700;
  padding: 6rpx 14rpx;
}

.review {
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.45;
  margin-bottom: 12rpx;
}

.preview {
  color: #475569;
  font-size: 24rpx;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
